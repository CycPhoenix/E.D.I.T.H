# ── E.D.I.T.H Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
OWNER_CHAT_ID=your-telegram-chat-id

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_TASK_DB=your-task-database-id
NOTION_PROJECT_DB=your-project-database-id
NOTION_KPI_DB=your-kpi-database-id
NOTION_CONTENT_DB=your-content-database-id
NOTION_RESEARCH_DB=your-research-database-id
NOTION_FOOD_DB=your_food_places_database_id_here

# ── Outlook Calendar ─────────────────────────────────────────────────────────
# Get this from Outlook Web → Settings → Calendar → Shared calendars → Publish
# Make sure to copy the full URL ending in /calendar.ics
OUTLOOK_ICS_URL=https://outlook.office365.com/owa/calendar/.../calendar.ics

# ── ElevenLabs (Voice) ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
